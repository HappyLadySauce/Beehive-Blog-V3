# Base URL for the running gateway HTTP service.
# 已启动 gateway HTTP 服务的基础地址。
BEEHIVE_QA_BASE_URL=http://127.0.0.1:8888

# HTTP timeout in seconds.
# HTTP 请求超时时间（秒）。
BEEHIVE_QA_TIMEOUT_SECONDS=5

# Whether TLS certificates should be verified.
# 是否校验 TLS 证书。
BEEHIVE_QA_VERIFY_SSL=false

# Default password used by generated regression users.
# 生成回归测试用户时使用的默认密码。
BEEHIVE_QA_DEFAULT_PASSWORD=Str0ngP@ssw0rd!

# Prefix used for generated usernames.
# 生成测试用户名时使用的前缀。
BEEHIVE_QA_TEST_USERNAME_PREFIX=qa_user

# Domain used for generated test emails.
# 生成测试邮箱时使用的域名。
BEEHIVE_QA_TEST_EMAIL_DOMAIN=example.test

# Toggle third-party SSO tests.
# 是否启用第三方 SSO 测试。
BEEHIVE_QA_ENABLE_SSO_TESTS=false
BEEHIVE_QA_GITHUB_ENABLED=false
BEEHIVE_QA_QQ_ENABLED=false
BEEHIVE_QA_WECHAT_ENABLED=false

